# ─── Network ─────────────────────────────────────────────────────────────────
# Use Sepolia testnet (true) or mainnet (false).
USE_TESTNET=false

# ─── Ethereum RPC (ENS — always mainnet) ────────────────────────────────────
# ENS resolution always uses Ethereum mainnet regardless of USE_TESTNET.
ENS_RPC_URL=https://ethereum.publicnode.com
# Legacy alias (optional):
# ETH_RPC_URL=https://ethereum.publicnode.com

# ─── Pinata IPFS ────────────────────────────────────────────────────────────
PINATA_GATEWAY_URL=your_gateway.mypinata.cloud
PINATA_GATEWAY_TOKEN=your_gateway_token_from_pinata_dashboard
PINATA_JWT=your_pinata_jwt_token

# ─── Sui RPC ──────────────────────────────────────────────────────────────
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# ─── Registry Backend ──────────────────────────────────────────────────────
# "turso" = persistent Turso cloud DB (production)
# anything else = ephemeral in-memory (local dev)
REGISTRY_BACKEND=turso
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ─── Security ───────────────────────────────────────────────────────────────
API_KEY=
ALLOWED_ORIGINS=*
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=30
MAX_BODY_SIZE=1048576

# ─── Optional ───────────────────────────────────────────────────────────────
ENABLE_CACHE=true
