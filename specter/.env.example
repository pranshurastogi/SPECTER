# ══════════════════════════════════════════════════════════════════════════════
# SPECTER API — Environment Variables Reference
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values. Never commit .env.
# All vars without a listed default are REQUIRED for that feature.
# For Railway deployment, see .env.railway.example.

# ─── Network Mode ─────────────────────────────────────────────────────────────
# Controls which chain is used for ENS resolution and on-chain operations.
#   true  → Ethereum Sepolia (testnet ENS, Monad testnet)
#   false → Ethereum mainnet
USE_TESTNET=false

# ─── Ethereum RPC ─────────────────────────────────────────────────────────────
# Primary RPC for ENS resolution. Switch to Sepolia URL when USE_TESTNET=true.
# Mainnet (USE_TESTNET=false):
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# Testnet (USE_TESTNET=true):
# ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ENS-specific RPC — always resolves against Ethereum mainnet because real .eth
# names live on L1 even when USE_TESTNET=true for other features.
# Falls back to ETH_RPC_URL if unset.
ENS_RPC_URL=https://ethereum.publicnode.com

# ─── Sui RPC ──────────────────────────────────────────────────────────────────
# Used for SuiNS name resolution (Sui equivalent of ENS).
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
# Testnet: SUI_RPC_URL=https://sui-testnet.g.alchemy.com/v2/YOUR_KEY

# ─── Monad ────────────────────────────────────────────────────────────────────
# Primary Monad testnet RPC — used by the relayer, e2e-flow, and chain indexer.
MONAD_RPC_URL=https://monad-testnet.g.alchemy.com/v2/YOUR_KEY

# SPECTERAnnouncer contract on Monad testnet.
# SPECTER_ANNOUNCER_DEPLOY_BLOCK: the block height at deploy — the indexer/poller
# starts scanning from here so it doesn't replay the entire chain history.
# Must stay in sync with SPECTER-web/.env and event-poller/.env.
SPECTER_ANNOUNCER_ADDRESS=0x7a687B5a7c98c880f23F00003A820e7E2fF7fDaC
SPECTER_ANNOUNCER_DEPLOY_BLOCK=37571591

# ─── Server-Side Relayer ──────────────────────────────────────────────────────
# When set, the API broadcasts announce() on Monad on behalf of the user,
# enabling gas-sponsored announcements — users never need MON tokens.
# Leave blank for dev mode (client supplies tx_hash directly).
# SECURITY: Never commit a funded private key. Use Railway secrets in production.
RELAYER_PRIVATE_KEY=

# ─── Encryption Key ───────────────────────────────────────────────────────────
# 32-byte base64 master key for at-rest hardening:
#   • deduplication MAC (prevents duplicate announcements)
#   • telemetry IP hashing (privacy)
#   • pending-secret wrapping (stealth key custody)
# Generate: openssl rand -base64 32
# REQUIRED in production when RELAYER_PRIVATE_KEY is set.
SPECTER_DB_ENC_KEY=

# ─── Source-Chain Payment Verification ────────────────────────────────────────
# Per-chain RPCs used to call eth_getTransactionReceipt before accepting an
# announcement. This prevents fake "I paid" claims from senders.
# Provide RPC URLs only for chains you want to verify — chains with no RPC skip verification.
CHAIN_RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
CHAIN_RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_RPC_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_RPC_MONAD_TESTNET=https://monad-testnet.g.alchemy.com/v2/YOUR_KEY

# ─── Registry Backend ─────────────────────────────────────────────────────────
# Where stealth-address registry entries are stored:
#   turso        → durable Turso cloud DB (use for staging + production)
#   anything else → ephemeral in-memory store (fine for quick local dev without Turso)
REGISTRY_BACKEND=turso
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ─── Pinata IPFS ──────────────────────────────────────────────────────────────
# Required for meta-address uploads (ENS/SuiNS attach flow) and IPFS retrieves.
# Get from: https://app.pinata.cloud → API Keys
PINATA_JWT=your_pinata_jwt
# Pinata Dedicated Gateway for faster IPFS retrievals.
PINATA_GATEWAY_URL=your_gateway.mypinata.cloud
# Gateway access token (Pinata dashboard → Gateways → your gateway → Access Tokens).
PINATA_GATEWAY_TOKEN=your_gateway_token

# ─── Security ─────────────────────────────────────────────────────────────────
# API_KEY: Bearer token clients must send in the X-API-Key header.
# Leave blank in local dev (auth disabled). Generate for production:
#   openssl rand -hex 32
API_KEY=

# ALLOWED_ORIGINS: comma-separated CORS origins. "*" = allow all (dev only).
ALLOWED_ORIGINS=https://specterpq.com,https://www.specterpq.com

# RATE_LIMIT_RPS / RATE_LIMIT_BURST: per-IP rate limiting.
# RPS = sustained requests/second; BURST = short-term spike allowance.
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=30

# MAX_BODY_SIZE: maximum request body size in bytes (1 MiB = 1048576).
MAX_BODY_SIZE=1048576

# ─── Misc ─────────────────────────────────────────────────────────────────────
# Enable in-process caching of registry reads to reduce DB load.
ENABLE_CACHE=true

# ANNOUNCEMENT_SOURCE: uncomment to use the built-in Rust chain indexer.
# Prefer the standalone event-poller/ service over this legacy path.
# ANNOUNCEMENT_SOURCE=chain
