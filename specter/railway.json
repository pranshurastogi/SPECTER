{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "Cargo.toml",
      "Cargo.lock",
      "Dockerfile",
      "railway.json",
      ".env.railway.example",
      "specter-api/**",
      "specter-cli/**",
      "specter-core/**",
      "specter-crypto/**",
      "specter-stealth/**",
      "specter-registry/**",
      "specter-scanner/**",
      "specter-ipfs/**",
      "specter-ens/**",
      "specter-yellow/**",
      "specter-suins/**"
    ]
  },
  "deploy": {
    "runtime": "V2",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
