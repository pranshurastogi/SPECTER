# ══════════════════════════════════════════════════════════════════════════════
# SPECTER API — Production Environment
# ══════════════════════════════════════════════════════════════════════════════
# Production is always mainnet. Use paid RPC providers — public nodes rate-limit in prod.

# ─── Network Mode ─────────────────────────────────────────────────────────────
# Production is always mainnet.
USE_TESTNET=false

# ─── Ethereum RPC ─────────────────────────────────────────────────────────────
# Use a paid, rate-limit-free provider (Alchemy, Infura, QuickNode).
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# ENS-specific RPC — dedicated endpoint for ENS lookups.
# Can use the same paid key as ETH_RPC_URL, or a separate one for traffic isolation.
ENS_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# ─── Sui RPC ──────────────────────────────────────────────────────────────────
# SuiNS resolution always uses Sui mainnet in production.
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# ─── Monad ────────────────────────────────────────────────────────────────────
# Monad testnet RPC — used by the relayer for broadcasting announce() transactions.
MONAD_RPC_URL=https://monad-testnet.g.alchemy.com/v2/your_alchemy_api_key

# SPECTERAnnouncer contract on Monad testnet.
# SPECTER_ANNOUNCER_DEPLOY_BLOCK: starting block for indexer/poller scans.
# Must stay in sync with SPECTER-web/.env and event-poller/.env.
SPECTER_ANNOUNCER_ADDRESS=0x7a687B5a7c98c880f23F00003A820e7E2fF7fDaC
SPECTER_ANNOUNCER_DEPLOY_BLOCK=37571591

# ─── Pinata IPFS ──────────────────────────────────────────────────────────────
# Required for meta-address uploads and IPFS retrieves.
# Use a production-isolated Pinata API key — never reuse staging credentials.
PINATA_GATEWAY_URL=your_prod_gateway.mypinata.cloud
PINATA_GATEWAY_TOKEN=your_prod_gateway_token
PINATA_JWT=your_prod_pinata_jwt

# ─── Registry Backend ─────────────────────────────────────────────────────────
# Production uses an isolated Turso database — NEVER reuse the staging DB.
REGISTRY_BACKEND=turso
TURSO_DATABASE_URL=libsql://your-prod-db.turso.io
TURSO_AUTH_TOKEN=your_prod_turso_auth_token

# ─── Server-Side Relayer ──────────────────────────────────────────────────────
# Set to a funded EOA private key to enable gas-sponsored announcements.
# SECURITY: Set via Railway secrets / CI env vars — never put the real key here.
RELAYER_PRIVATE_KEY=

# ─── Encryption Key ───────────────────────────────────────────────────────────
# 32-byte base64 master key for at-rest hardening (dedup MAC, IP hashing,
# pending-secret wrapping). Generate: openssl rand -base64 32
# REQUIRED in production when RELAYER_PRIVATE_KEY is set.
SPECTER_DB_ENC_KEY=

# ─── Source-Chain Payment Verification ────────────────────────────────────────
# Per-chain RPCs for verifying payments before accepting announcements.
# Omit a chain entry to skip verification for that chain.
CHAIN_RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key
CHAIN_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key
CHAIN_RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/your_alchemy_api_key
CHAIN_RPC_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/your_alchemy_api_key
CHAIN_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key
CHAIN_RPC_MONAD_TESTNET=https://monad-testnet.g.alchemy.com/v2/your_alchemy_api_key

# ─── Security ─────────────────────────────────────────────────────────────────
# Strong random API key — generate: openssl rand -hex 32
API_KEY=your_secure_production_api_key

# Restrict CORS to your production frontend origins only.
ALLOWED_ORIGINS=https://specterpq.com,https://www.specterpq.com

# Production rate limits (higher burst than staging to handle real traffic).
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=50

# Maximum request body size in bytes (1 MiB = 1048576).
MAX_BODY_SIZE=1048576

# ─── Misc ─────────────────────────────────────────────────────────────────────
# Enable in-process caching of registry reads to reduce DB load.
ENABLE_CACHE=true
