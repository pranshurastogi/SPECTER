# ══════════════════════════════════════════════════════════════════════════════
# SPECTER API — Staging Environment
# ══════════════════════════════════════════════════════════════════════════════
# Staging always runs on testnet chains.

# ─── Network Mode ─────────────────────────────────────────────────────────────
# Staging always uses testnet.
USE_TESTNET=true

# ─── Ethereum RPC ─────────────────────────────────────────────────────────────
# Sepolia RPC for ENS resolution in staging.
ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ENS always resolves against Ethereum mainnet (real .eth names live on L1).
# Falls back to ETH_RPC_URL if unset.
ENS_RPC_URL=https://ethereum.publicnode.com

# ─── Monad Testnet RPC ────────────────────────────────────────────────────────
# NOTE: The backend reads MONAD_RPC_URL — set this, not MONAD_TESTNET_RPC_URL.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# SPECTERAnnouncer contract on Monad testnet.
# SPECTER_ANNOUNCER_DEPLOY_BLOCK: starting block for indexer/poller scans.
# Must stay in sync with SPECTER-web/.env and event-poller/.env.
SPECTER_ANNOUNCER_ADDRESS=0x7a687B5a7c98c880f23F00003A820e7E2fF7fDaC
SPECTER_ANNOUNCER_DEPLOY_BLOCK=37571591

# ─── Sui RPC ──────────────────────────────────────────────────────────────────
# SuiNS resolution — testnet in staging.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# ─── Pinata IPFS ──────────────────────────────────────────────────────────────
# Use a staging-isolated Pinata API key — never reuse production credentials.
PINATA_GATEWAY_URL=your_staging_gateway.mypinata.cloud
PINATA_GATEWAY_TOKEN=your_staging_gateway_token
PINATA_JWT=your_staging_pinata_jwt

# ─── Registry Backend ─────────────────────────────────────────────────────────
# Staging uses a dedicated Turso database — NEVER point at the production DB.
REGISTRY_BACKEND=turso
TURSO_DATABASE_URL=libsql://your-staging-db.turso.io
TURSO_AUTH_TOKEN=your_staging_turso_auth_token

# ─── Server-Side Relayer ──────────────────────────────────────────────────────
# Set to a funded testnet EOA private key to enable gas-sponsored announcements.
# Leave blank to require clients to supply tx_hash directly.
RELAYER_PRIVATE_KEY=

# ─── Encryption Key ───────────────────────────────────────────────────────────
# 32-byte base64 master key for at-rest hardening. Generate: openssl rand -base64 32
# REQUIRED when RELAYER_PRIVATE_KEY is set.
SPECTER_DB_ENC_KEY=

# ─── Source-Chain Payment Verification ────────────────────────────────────────
# Per-chain RPCs for verifying payments before accepting announcements.
CHAIN_RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
CHAIN_RPC_ARBITRUM=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
CHAIN_RPC_MONAD_TESTNET=https://monad-testnet.g.alchemy.com/v2/YOUR_KEY

# ─── Security ─────────────────────────────────────────────────────────────────
# Bearer token for X-API-Key auth. Generate: openssl rand -hex 32
API_KEY=your_staging_api_key

# Restrict CORS to staging frontend origins.
ALLOWED_ORIGINS=https://staging.specterpq.com

# Per-IP rate limits.
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=30

# Maximum request body size in bytes (1 MiB = 1048576).
MAX_BODY_SIZE=1048576

# ─── Misc ─────────────────────────────────────────────────────────────────────
# Enable in-process caching of registry reads.
ENABLE_CACHE=true
