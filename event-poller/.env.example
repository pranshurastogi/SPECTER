# ══════════════════════════════════════════════════════════════════════════════
# SPECTER Event Poller — Environment Variables Reference
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values. Never commit .env.
# Turso creds MUST match specter/.env — both services share one DB.

# ─── Required ─────────────────────────────────────────────────────────────────

# Monad JSON-RPC endpoint used to poll for new blocks and fetch event logs.
# The poller calls eth_getLogs on the SPECTERAnnouncer contract at this endpoint.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# SPECTERAnnouncer contract address on Monad testnet.
SPECTER_ANNOUNCER_ADDRESS=0x7a687B5a7c98c880f23F00003A820e7E2fF7fDaC

# Block at which the contract was deployed — the poller starts scanning from
# this block if no checkpoint exists in the DB. Avoids replaying the full chain.
# Must stay in sync with SPECTER-web/.env and specter/.env.
SPECTER_ANNOUNCER_DEPLOY_BLOCK=37571591

# Turso database (must be the same instance the SPECTER API uses).
# The poller writes events here; the API reads them.
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# ─── Optional (defaults shown) ────────────────────────────────────────────────

# How often to poll for new blocks (milliseconds).
# Lower = lower latency, more RPC calls to Monad. Default: 10000 (10 seconds).
# POLL_INTERVAL_MS=10000

# How many block confirmations to wait before writing an event to Turso.
# Higher = safer against chain reorgs; lower = faster event delivery. Default: 2.
# CONFIRMATION_DEPTH=2

# Maximum number of blocks to fetch per poll cycle.
# Cap this to avoid oversized eth_getLogs responses on busy periods. Default: 500.
# MAX_BLOCKS_PER_POLL=500
