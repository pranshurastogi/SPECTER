# ── Required ──────────────────────────────────────────────────────────────────

# Monad JSON-RPC endpoint
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# SPECTERAnnouncer contract address
SPECTER_ANNOUNCER_ADDRESS=0xCc322132261cE3a1c9c85a6ef69779Ce2D61CA5a

# Block at which the contract was deployed (poller starts here if no checkpoint)
SPECTER_ANNOUNCER_DEPLOY_BLOCK=36100042

# Turso database (must be the same instance the API uses)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# ── Optional ──────────────────────────────────────────────────────────────────

# How often to poll for new blocks (milliseconds, default: 10000)
# POLL_INTERVAL_MS=10000

# How many confirmations to wait before writing (default: 2)
# CONFIRMATION_DEPTH=2

# Maximum blocks to fetch per poll cycle (default: 500)
# MAX_BLOCKS_PER_POLL=500
