# ─── SPECTER Indexer — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ─── Turso (libSQL) ───────────────────────────────────────────────────────────
# The SPECTER API registry database.
# Get these from: https://turso.tech  →  your database  →  Generate Token
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ─── Envio local ports ────────────────────────────────────────────────────────
# Hasura is on 8181 because 8080 is taken by the SPECTER-web Vite dev server.
HASURA_GRAPHQL_ENDPOINT=http://localhost:8181/v1/metadata
HASURA_EXTERNAL_PORT=8181

# ─── Turso retry worker ────────────────────────────────────────────────────────
# The retrySync worker queries Envio GraphQL for tursoSynced=false events and
# re-pushes them to Turso. Tweak these if you need to adjust the behaviour.

# GraphQL endpoint for Envio's local Hasura instance.
# Derived automatically from HASURA_EXTERNAL_PORT if not set.
# Only override this if your Hasura runs on a non-standard host or port.
# ENVIO_GRAPHQL_URL=http://localhost:8181/v1/graphql

# How often the retry cycle runs (milliseconds). Default: 300000 (5 minutes).
# TURSO_RETRY_INTERVAL_MS=300000

# Maximum number of unsynced events to fetch and retry per cycle. Default: 5000.
# If you hit this limit, consider running a full re-index or increasing this value.
# TURSO_RETRY_MAX_FETCH=5000

# ─── Monad RPC (optional override) ────────────────────────────────────────────
# Envio uses HyperSync for Monad by default (no RPC needed).
# Only set this if you need to override the public HyperSync endpoint.
# MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# ─── Envio Hosted Service (optional) ──────────────────────────────────────────
# Only needed when deploying to Envio's hosted indexing service.
# Get from: https://envio.dev  →  your project  →  Settings
# ENVIO_API_TOKEN=your-envio-api-token
