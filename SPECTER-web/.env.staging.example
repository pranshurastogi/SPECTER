# ─── SPECTER Frontend — Staging ──────────────────────────────────────────────

VITE_APP_DEPLOYMENT=staging

VITE_API_BASE_URL=https://staging-backend.specterpq.com

# ENS resolution
VITE_ENS_RESOLUTION_TIMEOUT_MS=5000
VITE_ENS_CACHE_TTL_MS=300000

# Sepolia testnet RPC
VITE_ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
VITE_ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
VITE_MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# Monad testnet — SPECTERAnnouncer contract
VITE_SPECTER_ANNOUNCER_ADDRESS=0xCc322132261cE3a1c9c85a6ef69779Ce2D61CA5a
VITE_SPECTER_ANNOUNCER_DEPLOY_BLOCK=36100042

# Dynamic.xyz — create a Sandbox environment at app.dynamic.xyz
VITE_DYNAMIC_ENVIRONMENT_ID=your-staging-dynamic-environment-id

# Testnet
VITE_USE_TESTNET=true
