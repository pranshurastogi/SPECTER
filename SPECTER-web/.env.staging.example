# ══════════════════════════════════════════════════════════════════════════════
# SPECTER Frontend — Staging Environment
# ══════════════════════════════════════════════════════════════════════════════
# Staging always points at testnet chains.

# ─── Deployment Tier ──────────────────────────────────────────────────────────
# "staging" enables staging-only banners and unreleased feature flags.
VITE_APP_DEPLOYMENT=staging

# ─── Backend API ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://staging-backend.specterpq.com

# ─── Wallet SDK ───────────────────────────────────────────────────────────────
# Create a Sandbox environment at app.dynamic.xyz for staging.
VITE_DYNAMIC_ENVIRONMENT_ID=your-staging-dynamic-environment-id

# ─── Network Mode ─────────────────────────────────────────────────────────────
# Staging always uses testnet for both ENS and stealth-address setup.
VITE_USE_TESTNET=true

# Staging also uses testnet chains in the send-payment flow.
VITE_SEND_USE_TESTNET=true

# ─── Ethereum RPCs ────────────────────────────────────────────────────────────
# All testnet in staging.
VITE_ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Sepolia RPC for ENS resolution and send-payment flow.
VITE_ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ENS-only endpoint (can stay on a free public node in staging).
VITE_ENS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Additional testnet send-payment chain RPCs.
VITE_ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
VITE_MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# ─── ENS Resolution Tuning ────────────────────────────────────────────────────
# Timeout (ms) for ENS RPC calls.
VITE_ENS_RESOLUTION_TIMEOUT_MS=5000

# Client-side cache TTL (ms) for resolved ENS names. 300000 = 5 minutes.
VITE_ENS_CACHE_TTL_MS=300000

# ─── SPECTERAnnouncer Contract ────────────────────────────────────────────────
# On-chain contract on Monad testnet. Must match event-poller/.env.
VITE_SPECTER_ANNOUNCER_ADDRESS=0xCc322132261cE3a1c9c85a6ef69779Ce2D61CA5a
VITE_SPECTER_ANNOUNCER_DEPLOY_BLOCK=36100042

# ─── Yellow Network (Sandbox / testnet) ───────────────────────────────────────
# Sandbox RPCs used when VITE_SEND_USE_TESTNET=true.
# Chain IDs: Sepolia (11155111), Base Sepolia (84532), Polygon Amoy (80002)
VITE_YELLOW_SANDBOX_RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
VITE_YELLOW_SANDBOX_RPC_BASE=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
VITE_YELLOW_SANDBOX_RPC_POLYGON=https://rpc-amoy.polygon.technology
