# ══════════════════════════════════════════════════════════════════════════════
# SPECTER Frontend — Production Environment
# ══════════════════════════════════════════════════════════════════════════════
# Production always points at mainnet chains.
# Use paid RPC providers (Alchemy, Infura, QuickNode) — public nodes rate-limit in prod.

# ─── Deployment Tier ──────────────────────────────────────────────────────────
# "main" = production mode (no staging banners or feature flags).
VITE_APP_DEPLOYMENT=main

# ─── Backend API ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://backend.specterpq.com

# ─── Wallet SDK ───────────────────────────────────────────────────────────────
# Use the Live environment ID from app.dynamic.xyz (not the Sandbox one).
VITE_DYNAMIC_ENVIRONMENT_ID=your-prod-dynamic-environment-id

# ─── Network Mode ─────────────────────────────────────────────────────────────
# Production is always mainnet for both ENS and stealth-address setup.
VITE_USE_TESTNET=false

# Production send-payment flow uses mainnet chains.
VITE_SEND_USE_TESTNET=false

# ─── Ethereum RPCs ────────────────────────────────────────────────────────────
# Primary ETH RPC for ENS resolution and mainnet stealth setup.
# Use a paid provider to avoid rate limits.
VITE_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# Sepolia RPC — unused in production (VITE_SEND_USE_TESTNET=false).
# Leave blank or remove to disable testnet flows.
VITE_ETH_SEPOLIA_RPC_URL=

# ENS-only RPC — dedicated endpoint for ENS lookups.
# Consider a paid endpoint here too for high-traffic deployments.
VITE_ENS_RPC_URL=https://ethereum.publicnode.com

# Testnet send-payment RPCs — unused in production (VITE_SEND_USE_TESTNET=false).
VITE_ARB_SEPOLIA_RPC_URL=
VITE_MONAD_TESTNET_RPC_URL=

# ─── ENS Resolution Tuning ────────────────────────────────────────────────────
# Timeout (ms) for ENS RPC calls.
VITE_ENS_RESOLUTION_TIMEOUT_MS=5000

# Client-side cache TTL (ms) for resolved ENS names. 300000 = 5 minutes.
VITE_ENS_CACHE_TTL_MS=300000

# ─── SPECTERAnnouncer Contract ────────────────────────────────────────────────
# On-chain contract on Monad testnet. Update when deploying a new contract version.
# Must stay in sync with event-poller/.env and specter/.env.
VITE_SPECTER_ANNOUNCER_ADDRESS=0x7a687B5a7c98c880f23F00003A820e7E2fF7fDaC
VITE_SPECTER_ANNOUNCER_DEPLOY_BLOCK=37571591

# ─── Yellow Network (Production / mainnet) ────────────────────────────────────
# Mainnet RPCs used when VITE_SEND_USE_TESTNET=false.
# Chain IDs: ETH (1), Base (8453), Polygon (137), BNB (56), Linea (59144)
VITE_YELLOW_MAINNET_RPC_ETH=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key
VITE_YELLOW_MAINNET_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key
VITE_YELLOW_MAINNET_RPC_POLYGON=https://polygon-rpc.com
VITE_YELLOW_MAINNET_RPC_BSC=https://bsc-dataseed.binance.org
VITE_YELLOW_MAINNET_RPC_LINEA=https://rpc.linea.build
