# ─── SPECTER Frontend — Production ───────────────────────────────────────────

VITE_API_BASE_URL=https://backend.specterpq.com

# ENS resolution
VITE_ENS_RESOLUTION_TIMEOUT_MS=5000
VITE_ENS_CACHE_TTL_MS=300000

# Ethereum mainnet — use a paid provider
VITE_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# Dynamic.xyz — use the Live environment ID from app.dynamic.xyz
VITE_DYNAMIC_ENVIRONMENT_ID=your-prod-dynamic-environment-id

# Mainnet
VITE_USE_TESTNET=false
