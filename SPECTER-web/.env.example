# ══════════════════════════════════════════════════════════════════════════════
# SPECTER Frontend — Environment Variables Reference
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values. Never commit .env.
# For staging/production, see .env.staging.example / .env.production.example.

# ─── Deployment Tier ──────────────────────────────────────────────────────────
# Controls which UI features and banners are visible:
#   staging → enables staging-only banners / unreleased feature flags
#   main    → production mode (default when unset)
VITE_APP_DEPLOYMENT=main

# ─── Backend API ──────────────────────────────────────────────────────────────
# SPECTER API base URL. For local dev, start the backend with:
#   cargo run --bin specter -- serve --port 3001
VITE_API_BASE_URL=http://localhost:3001

# ─── Wallet SDK ───────────────────────────────────────────────────────────────
# Dynamic.xyz SDK environment ID — controls which wallet connections are shown.
# Get from: https://app.dynamic.xyz → your app → API
# Use a Sandbox ID for dev/staging; a Live ID for production.
VITE_DYNAMIC_ENVIRONMENT_ID=your-dynamic-environment-id

# ─── Network Mode ─────────────────────────────────────────────────────────────
# VITE_USE_TESTNET: governs the chain used for ENS resolution and SPECTER core features.
#   true  → Ethereum Sepolia (testnet ENS names, testnet stealth-address setup)
#   false → Ethereum mainnet (live .eth names, mainnet stealth-address setup)
VITE_USE_TESTNET=true

# VITE_SEND_USE_TESTNET: independent flag for the multi-chain send-payment flow.
#   true  → Sepolia + Arb Sepolia + Monad testnet + Sui testnet
#   false → Ethereum mainnet + other production chains
# Decoupled from VITE_USE_TESTNET so you can resolve ENS on mainnet
# while sending payments on testnet chains (common during staging QA).
VITE_SEND_USE_TESTNET=true

# ─── Ethereum RPCs ────────────────────────────────────────────────────────────
# Primary ETH RPC — used for ENS resolution and stealth-address setup.
# Set to a Sepolia URL when VITE_USE_TESTNET=true.
VITE_ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Sepolia RPC — used for:
#   1. ENS resolution when VITE_USE_TESTNET=true
#   2. Send-payment flow when VITE_SEND_USE_TESTNET=true
VITE_ETH_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ENS-only public RPC — dedicated endpoint for ENS lookups so it never contends
# with transaction RPCs. Falls back to VITE_ETH_RPC_URL if unset.
VITE_ENS_RPC_URL=https://ethereum.publicnode.com

# Additional send-payment chain RPCs (only used when VITE_SEND_USE_TESTNET=true)
VITE_ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
VITE_MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# ─── ENS Resolution Tuning ────────────────────────────────────────────────────
# Maximum time (ms) to wait for an ENS resolution RPC call before timing out.
VITE_ENS_RESOLUTION_TIMEOUT_MS=5000

# Client-side TTL (ms) for cached ENS name → address resolutions.
# 300000 = 5 minutes — reduces repeated RPC calls for the same name.
VITE_ENS_CACHE_TTL_MS=300000

# ─── SPECTERAnnouncer Contract ────────────────────────────────────────────────
# The on-chain contract deployed on Monad testnet that emits Announcement events.
# VITE_SPECTER_ANNOUNCER_DEPLOY_BLOCK: the block to start scanning from (avoids
# replaying the entire chain history on fresh indexer/poller runs).
# These values must stay in sync with event-poller/.env and specter/.env.
VITE_SPECTER_ANNOUNCER_ADDRESS=0x7a687B5a7c98c880f23F00003A820e7E2fF7fDaC
VITE_SPECTER_ANNOUNCER_DEPLOY_BLOCK=37571591

# ─── Yellow Network ───────────────────────────────────────────────────────────
# Off-chain payment channel / state-channel layer for multi-chain sends.
# Reference: https://docs.yellow.org/docs/learn/introduction/supported-chains/

# Sandbox (testnet) RPCs — active when VITE_SEND_USE_TESTNET=true
# Supported chain IDs: Sepolia (11155111), Base Sepolia (84532), Polygon Amoy (80002)
VITE_YELLOW_SANDBOX_RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
VITE_YELLOW_SANDBOX_RPC_BASE=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
VITE_YELLOW_SANDBOX_RPC_POLYGON=https://rpc-amoy.polygon.technology

# Production (mainnet) RPCs — active when VITE_SEND_USE_TESTNET=false
# Supported chain IDs: ETH (1), Base (8453), Polygon (137), BNB (56), Linea (59144)
VITE_YELLOW_MAINNET_RPC_ETH=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
VITE_YELLOW_MAINNET_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
VITE_YELLOW_MAINNET_RPC_POLYGON=https://polygon-rpc.com
VITE_YELLOW_MAINNET_RPC_BSC=https://bsc-dataseed.binance.org
VITE_YELLOW_MAINNET_RPC_LINEA=https://rpc.linea.build

# ─── Script-Only Variables ────────────────────────────────────────────────────
# Used exclusively by scripts/test-yellow-flow.mjs — NOT read by the Vite app.
# PRIVATE_KEY: test wallet EOA private key (fund via https://faucet.sepolia.dev).
# ALCHEMY_RPC_URL: RPC endpoint for the Yellow flow test script.
PRIVATE_KEY=0x_your_test_private_key
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
VITE_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=502024
