# Deployment tier for the SPA: `staging` enables staging-only UI; `main` = production (default if unset)
VITE_APP_DEPLOYMENT=main

# SPECTER API base URL (backend: cargo run --bin specter -- serve --port 3001)
VITE_API_BASE_URL=http://localhost:3001

# ENS Resolution Configuration
VITE_ENS_RESOLUTION_TIMEOUT_MS=5000
VITE_ENS_CACHE_TTL_MS=300000

# Ethereum RPC URL - use Sepolia RPC when VITE_USE_TESTNET=true, mainnet otherwise
VITE_ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Additional EVM testnet RPCs for Send Payment
VITE_ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
VITE_MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# Dynamic.xyz wallet SDK
VITE_DYNAMIC_ENVIRONMENT_ID=your-dynamic-environment-id

# Chain: Sepolia (testnet) or mainnet. Set to false for mainnet.
VITE_USE_TESTNET=true
